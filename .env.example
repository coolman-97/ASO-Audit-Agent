# ─────────────────────────────────────────────────────────────────────────────
# LLM provider (OpenAI-compatible)
# ─────────────────────────────────────────────────────────────────────────────
# Default is NVIDIA NIM (free credits at https://build.nvidia.com).
# Because the agent talks to an OpenAI-compatible endpoint, you can point these
# at OpenAI, Together, Groq, Ollama, etc. by changing the BASE_URL + model ids.

LLM_API_KEY=nvapi-your-key-here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model used for reasoning / structured audit scoring. Must support tool calling
# + JSON output. Good NIM choices: meta/llama-3.3-70b-instruct, qwen/qwen2.5-72b-instruct.
LLM_MODEL=meta/llama-3.3-70b-instruct

# Vision-capable model used to analyze screenshots + icon. Optional - if the
# model can't do vision the audit gracefully falls back to metadata-only scoring.
# Good NIM choice: meta/llama-3.2-90b-vision-instruct
LLM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# ─────────────────────────────────────────────────────────────────────────────
# Firecrawl (OPTIONAL) - https://firecrawl.dev
# ─────────────────────────────────────────────────────────────────────────────
# The subtitle / preview-video presence are extracted reliably WITHOUT a key via
# a small keyless parse of the App Store web page. A Firecrawl key is only an
# optional upgrade for more robust promotional-text extraction. Safe to leave blank.
FIRECRAWL_API_KEY=
